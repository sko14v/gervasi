{
  "permissions": {
    "allow": [
      "Bash(dir *)",
      "Bash(npm run *)",
      "Bash(ffmpeg *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(powershell *)",
      "Bash(select-object *)",
      "Bash(del *)",
      "Bash($env:agentik_vault_path *)",
      "Bash(ping *)",
      "Bash(curl *)"
    ]
  },
  "$version": 4
}